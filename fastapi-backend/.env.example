# Tablestore 配置
OTS_ENDPOINT=https://hbti-prod.cn-hangzhou.ots.aliyuncs.com
OTS_INSTANCE=hbti-prod
OTS_TABLE=hbti_stats
OTS_ACCESS_KEY_ID=your_access_key_id
OTS_ACCESS_KEY_SECRET=your_access_key_secret

# MySQL 数据库配置
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/hbti?charset=utf8mb4

# JWT 密钥 (生成: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=your-secret-key-change-in-production

# CORS
ALLOW_ORIGIN=*
